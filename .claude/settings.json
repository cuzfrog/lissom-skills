{
  "permissions": {
    "deny": [
      "Read(deprecated/**)",
      "Read(tmp/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash dev/update-version-timestamp.sh",
            "statusMessage": "Updating version timestamp..."
          }
        ]
      },
      {
        "matcher": "Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash dev/check-install-scripts.sh"
          }
        ]
      }
    ]
  }
}
